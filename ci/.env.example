# Copiar a .env y rellenar (nunca subir el .env real a git).

# Contraseña de la base de datos de SonarQube.
SONAR_DB_PASSWORD=

# Usuario/contraseña del admin de Jenkins (config as code, sin setup wizard).
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=

# PAT de GitHub (fine-grained, Contents: Read) sobre el repo 2mino.
GITHUB_USERNAME=
GITHUB_TOKEN=

# Token de SonarQube — se genera DESPUÉS de levantar sonarqube (ver docs/CI.md).
SONAR_TOKEN=
