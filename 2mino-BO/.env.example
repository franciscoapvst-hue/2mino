# Selector de ambiente (Dev/QA/Prod) — ver src/lib/env.ts.

# Dev: api-integracion del Docker local.
VITE_API_URL_DEV=http://localhost:3000

# QA: no existe ambiente todavía — dejar vacío. El botón "QA" del panel
# queda deshabilitado hasta que se configure una URL acá.
VITE_API_URL_QA=

# Prod: SIEMPRE vía túnel SSH hacia el VPS, nunca un dominio público
# (ver docs/CASOS_DE_USO_BACKOFFICE.md §10.1):
#   ssh -N -L 3001:127.0.0.1:3000 root@74.208.119.150
# Puerto 3001 (no 3000) para no chocar con el api-integracion local —
# así podés tener Dev y Prod accesibles al mismo tiempo.
VITE_API_URL_PROD=http://localhost:3001
