# Copiar a .env y rellenar con valores reales
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=cambia_esto_en_produccion

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Dominio público — Caddy lo usa para pedir el certificado TLS (Let's Encrypt)
# Requiere que el registro A (y el de www) ya apunten a la IP del VPS
DOMAIN=2mino.online

# CORS — en producción poner el dominio exacto del frontend, con https
CORS_ORIGIN=https://2mino.online

# Email — poner true cuando se integre el proveedor (SendGrid, Resend, SES, etc.)
ENABLE_EMAIL=false

# Login con Google — Client ID de OAuth (no es secreto, se usa también en el
# frontend). Se genera en Google Cloud Console > APIs & Services > Credentials.
# Si se deja vacío, el botón de Google queda deshabilitado.
GOOGLE_CLIENT_ID=

# Client secret del mismo OAuth Client ID — ESTE SÍ ES SECRETO, solo lo usa
# el backend (api-integracion) para cambiar el authorization code por
# tokens. Nunca va al frontend ni se commitea.
GOOGLE_CLIENT_SECRET=
