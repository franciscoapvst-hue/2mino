# Copiar a .env y rellenar con valores reales
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=cambia_esto_en_produccion

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Dominio público — Caddy lo usa para pedir el certificado TLS (Let's Encrypt)
# Requiere que el registro A (y el de www) ya apunten a la IP del VPS
DOMAIN=2mino.online

# CORS — en producción poner el dominio exacto del frontend, con https
CORS_ORIGIN=https://2mino.online

# Email — confirmación de cuenta al registrarse (ms-usuarios). Con
# ENABLE_EMAIL=false no se manda nada de verdad, solo se loguea (útil para
# dev local sin credenciales SMTP reales) — igual queda accesible el token
# de verificación en la respuesta del registro (_dev_token, solo fuera de
# producción) para poder probar el flujo sin bandeja de entrada real.
ENABLE_EMAIL=false

# SMTP para mandar esos emails — casilla de IONOS Mail ya existente
# (administration@2mino.online), ver docs/ARQUITECTURA.md.
SMTP_HOST=smtp.ionos.com
SMTP_PORT=465
SMTP_USER=administration@2mino.online
SMTP_PASS=
SMTP_FROM=2mino <administration@2mino.online>

# Base URL pública — se usa para armar el link del email de confirmación
# (https://APP_URL/verificar-email/:token). Normalmente igual a DOMAIN
# pero con protocolo.
APP_URL=https://2mino.online

# Login con Google — Client ID de OAuth (no es secreto, se usa también en el
# frontend). Se genera en Google Cloud Console > APIs & Services > Credentials.
# Si se deja vacío, el botón de Google queda deshabilitado.
GOOGLE_CLIENT_ID=

# Client secret del mismo OAuth Client ID — ESTE SÍ ES SECRETO, solo lo usa
# el backend (api-integracion) para cambiar el authorization code por
# tokens. Nunca va al frontend ni se commitea.
GOOGLE_CLIENT_SECRET=

# Google AdSense — ninguno es secreto (van al bundle del frontend). Si se
# deja el client ID vacío, no se muestra ningún anuncio (no rompe el layout).
# Client ID: se genera en adsense.google.com, requiere aprobación del sitio.
# Cada slot es el ID de una unidad de anuncio distinta (dashboard, pantalla
# de "buscando partida", y entre manos) — se crean una vez aprobado el sitio.
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_DASHBOARD=
ADSENSE_SLOT_MATCHMAKING=
ADSENSE_SLOT_MANO=
